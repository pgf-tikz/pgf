\documentclass{article}
\input{regression-test}
\usepackage{pgfmath}

\begin{document}

\START

\BEGINTEST{hypot: corner cases}

\def\testhypot#1#2#3{%
  \begingroup
    \pgfmathparse{#1}%
    \let\lhs\pgfmathresult
    \pgfmathparse{#2}%
    \let\rhs\pgfmathresult
    \pgfmathparse{#3}%
    \let\expected\pgfmathresult
    %
    \pgfmathparse{hypot((\lhs),(\rhs))}%
    \let\testresult\pgfmathresult
    \TYPE{hypot(\lhs,\rhs) => actual: \testresult, expected: \expected}%
  \endgroup
}
\testhypot{0}{0}{0}
\testhypot{11111}{0}{11111}
\testhypot{0}{11111}{11111}

\ENDTEST

\BEGINTEST{hypot: Pythagorean triples}

\def\testhypot#1#2#3{%
  \begingroup
    \pgfmathparse{#1}%
    \let\lhs\pgfmathresult
    \pgfmathparse{#2}%
    \let\rhs\pgfmathresult
    \pgfmathparse{#3}%
    \let\expected\pgfmathresult
    %
    \pgfmathparse{hypot((\lhs),(\rhs))}%
    \let\testresult\pgfmathresult
    \pgfmathparse{abs((\testresult) - (\expected))}%
    \let\testabserr\pgfmathresult
    \pgfmathparse{(\testabserr) / max(\testresult,(\expected))}%
    \let\testrelerr\pgfmathresult
    \TYPE{hypot(\lhs,\rhs) => actual: \testresult, expected: \expected, abs: \testabserr, rel: \testrelerr}%
  \endgroup
}
\testhypot{ -3}{  4}{  5}
\testhypot{ -4}{  3}{  5}
\testhypot{  5}{-12}{ 13}
\testhypot{ 12}{  5}{ 13}
\testhypot{ -8}{ 15}{ 17}
\testhypot{ 15}{  8}{ 17}
\testhypot{  7}{ 24}{ 25}
\testhypot{-24}{ -7}{ 25}
\testhypot{ 20}{ 99}{101}
\testhypot{ 99}{ 20}{101}
\testhypot{ 68}{285}{293}
\testhypot{285}{ 68}{293}

\ENDTEST

\END
